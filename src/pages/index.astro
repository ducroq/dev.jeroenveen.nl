---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Augur — Energy Price Forecasting',
    desc: 'Week-ahead electricity price predictions for the Netherlands. 18+ energy market APIs, XGBoost ML pipeline with online learning, interactive Plotly dashboard.',
    tags: ['Python', 'XGBoost', 'River', 'Hugo', 'Plotly.js', 'Netlify'],
    link: 'https://energy.jeroenveen.nl',
    linkLabel: 'Live',
    accent: '#38bdf8',
    img: '/screenshots/augur.png',
  },
  {
    title: 'ese-bot — Chat with Your Docs',
    desc: 'EU-compliant RAG system serving 500+ students. Query academic documents in natural language with local embeddings and GDPR-safe logging.',
    tags: ['FastAPI', 'Vue.js', 'Weaviate', 'Mistral AI', 'Docker'],
    link: 'https://ese-bot.jeroenveen.nl',
    linkLabel: 'Live',
    accent: '#fb923c',
  },
  {
    title: 'ovr.news — Intelligence Pipeline',
    desc: '1500+ RSS feeds, GPU-scored ML filtering, automated publishing. Curated news intelligence updated every 15 minutes.',
    tags: ['Python', 'TypeScript', 'ML Scoring', 'Next.js'],
    link: 'https://ovr.news',
    linkLabel: 'Live',
    accent: '#f0a830',
    img: '/screenshots/ovr-news.png',
  },
  {
    title: 'vmodel.eu — Requirements Review',
    desc: 'AI-powered V-model validation across 50+ requirement types. Automated traceability checks and compliance scoring for engineering specifications.',
    tags: ['Python', 'NLP', 'RAG', 'SaaS'],
    link: 'https://vmodel.eu',
    linkLabel: 'Live',
    accent: '#34d399',
    img: '/screenshots/vmodel.png',
  },
  {
    title: 'DSP Workshop',
    desc: 'Digital signal processing — from math to metal. 6-chapter learning path, 15 topics, 114 exercises. From theory through Python to embedded C on real microcontrollers.',
    tags: ['Python', 'NumPy', 'SciPy', 'Quarto', 'DSP', 'Embedded C'],
    link: 'https://ducroq.github.io/dsp-workshop',
    linkLabel: 'Live',
    accent: '#2dd4bf',
    img: '/screenshots/dsp-workshop.png',
  },
  {
    title: 'Aegis — Portfolio Risk Early Warning',
    desc: 'Four-layer macro risk monitor with live dashboard. Backtested against every major crisis since 2000, automated daily updates.',
    tags: ['Python', 'FRED API', 'Quantitative', 'Netlify'],
    link: 'https://aegis.jeroenveen.nl',
    linkLabel: 'Live',
    accent: '#f87171',
    img: '/screenshots/aegis.png',
  },
  {
    title: 'Augmented Engineering',
    desc: 'Four patterns from nine real projects: what\'s genuinely new when engineers work with AI agents. Layered verification, context architecture, and evidence-based practice.',
    tags: ['Systems Engineering', 'AI Agents', 'V&V', 'Methodology'],
    link: 'https://ducroq.github.io/augmented-engineering',
    linkLabel: 'Live',
    accent: '#a78bfa',
    img: '/screenshots/augmented-engineering.png',
  },
  {
    title: 'Synthetic Podcast Production',
    desc: '30 synthetic voices, multilingual TTS pipeline, 300+ plays/episode. Full methodology from research to mastered audio.',
    tags: ['Python', 'Chatterbox', 'ElevenLabs', 'FFmpeg', 'Astro'],
    link: 'https://ducroq.github.io/podcast-generator',
    linkLabel: 'Demo',
    accent: '#f472b6',
    img: '/screenshots/podcast-generator.png',
  },
];
---

<Layout title="Jeroen Veen — Research & Engineering">
  <a href="#projects" class="skip-nav">Skip to projects</a>
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-label">dev.jeroenveen.nl</p>
        <h1 class="hero-title">Research & Engineering</h1>
        <p class="hero-subtitle">
          Production systems that ship — ML pipelines processing 1500+ feeds,
          energy forecasters on 18 APIs, embedded DSP on bare metal.
          <span class="hero-credentials">PhD (TU/e) · Philips Research · HAN University</span>
        </p>
      </div>
    </section>

    <!-- Projects -->
    <section class="section" id="projects">
      <span class="section-label">Projects</span>

      <div class="project-grid">
        {projects.map((p) => (
          <div class="project-card" style={`--card-accent: ${p.accent}`}>
            {p.img && (
              <div class="project-img">
                <img src={p.img} alt={`Screenshot of ${p.title}`} loading="lazy" />
              </div>
            )}
            <h2 class="project-title">{p.title}</h2>
            <p class="project-desc">{p.desc}</p>
            <div class="project-tags">
              {p.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            {p.link && (
              <a href={p.link} class="project-link" target="_blank" rel="noopener" aria-label={`${p.linkLabel} — ${p.title}`}>
                {p.linkLabel}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Bio -->
    <section class="section" id="about">
      <span class="section-label">Background</span>
      <div class="bio">
        <p>
          Engineering researcher at HAN University of Applied Sciences, working across AI/ML,
          biomedical engineering, embedded systems, and energy systems. My research spans rapid
          antibiotic susceptibility testing, point-of-care diagnostics, computer vision for
          Parkinson biomarkers, and AI-augmented engineering education.
        </p>
        <p>
          Previously at Philips Research. PhD from Eindhoven University of Technology (TU/e).
          Patent holder. I care about building systems that work in production, not just in notebooks.
        </p>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <nav class="footer-links">
      <a href="https://github.com/ducroq" target="_blank" rel="noopener">GitHub</a>
      <span class="sep">/</span>
      <a href="https://linkedin.com/in/jeroenveen" target="_blank" rel="noopener">LinkedIn</a>
      <span class="sep">/</span>
      <a href="https://jeroenveen.nl" target="_blank" rel="noopener">jeroenveen.nl</a>
      <span class="sep">/</span>
      <a href="https://jeroenveen.nl/contact/" target="_blank" rel="noopener">Contact</a>
    </nav>
  </footer>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, var(--amber-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 640px;
    text-align: center;
    position: relative;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-family: var(--font-mono);
    color: var(--amber);
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  .hero-credentials {
    display: block;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: var(--text-dim);
  }

  /* ── Section ── */
  .section {
    padding: 5rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1rem;
    display: block;
  }

  .section-title {
    margin-bottom: 2.5rem;
  }

  /* ── Project Grid ── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.25rem;
  }

  .project-card {
    --card-accent: var(--amber);
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 2px solid var(--card-accent);
    border-radius: 12px;
    padding: 0;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    overflow: hidden;
  }
  .project-card > :not(.project-img) {
    padding-left: 1.75rem;
    padding-right: 1.75rem;
  }
  .project-card > .project-title {
    padding-top: 1.75rem;
  }
  .project-card > .project-link {
    padding-bottom: 1.75rem;
  }
  /* Cards without an image still get inner padding */
  .project-card:not(:has(.project-img)) {
    padding: 1.75rem;
  }
  .project-card:not(:has(.project-img)) > :not(.project-img) {
    padding-left: 0;
    padding-right: 0;
  }
  .project-card:not(:has(.project-img)) > .project-title {
    padding-top: 0;
  }
  .project-card:not(:has(.project-img)) > .project-link {
    padding-bottom: 0;
  }
  .project-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .project-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
  .project-card:hover {
    border-color: color-mix(in srgb, var(--card-accent) 50%, transparent);
    border-top-color: var(--card-accent);
    box-shadow: 0 0 24px color-mix(in srgb, var(--card-accent) 15%, transparent);
    transform: translateY(-2px);
  }

  .project-title {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    margin-bottom: 0.5rem;
  }

  .project-desc {
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    flex: 1;
  }

  .project-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--surface-hover);
    border: 1px solid var(--border-subtle);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--card-accent);
    min-height: 44px;
    min-width: 44px;
  }
  .project-link:hover {
    color: var(--text);
  }

  /* ── Bio ── */
  .bio {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bio p {
    font-size: 1rem;
    line-height: 1.7;
  }

  /* ── Footer ── */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 3rem 1.5rem;
    text-align: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .sep {
    color: var(--text-dim);
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: 50vh;
      padding: 4rem 1.5rem 2rem;
    }
  }
</style>
