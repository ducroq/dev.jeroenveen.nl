---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Synthetic Podcast Production',
    desc: '30 synthetic voices, multilingual TTS pipeline, 300+ plays/episode. Full methodology from research to mastered audio.',
    tags: ['Python', 'Chatterbox', 'ElevenLabs', 'FFmpeg', 'Astro'],
    link: 'https://ducroq.github.io/podcast-generator',
    linkLabel: 'Demo',
  },
  {
    title: 'Working with AI Agents',
    desc: 'Methodology for AI-augmented software development. Tested across 100+ sessions with measurable productivity gains.',
    tags: ['Claude Code', 'Cursor', 'Methodology', 'DX'],
    link: 'https://github.com/ducroq/agent-ready-projects',
    linkLabel: 'GitHub',
  },
  {
    title: 'ovr.news — Intelligence Pipeline',
    desc: '1500+ RSS feeds, GPU-scored ML filtering, automated publishing. Curated news intelligence updated every 15 minutes.',
    tags: ['Python', 'TypeScript', 'ML Scoring', 'Next.js'],
    link: 'https://ovr.news',
    linkLabel: 'Live',
  },
  {
    title: 'vmodel.eu — Requirements Review',
    desc: 'AI-powered V-model validation for engineering documents. Automated traceability checks across specifications.',
    tags: ['Python', 'NLP', 'RAG', 'SaaS'],
    link: 'https://vmodel.eu',
    linkLabel: 'Live',
  },
  {
    title: 'ese-bot — Chat with Your Docs',
    desc: 'EU-compliant RAG system for querying academic documents with natural language. Local embeddings, GDPR-safe chat logging, Dockerized.',
    tags: ['FastAPI', 'Vue.js', 'Weaviate', 'Mistral AI', 'Docker'],
    link: 'https://ese-bot.jeroenveen.nl',
    linkLabel: 'Live',
  },
  {
    title: 'SU2049 — V&V for Critical Systems',
    desc: '91% test coverage, 72% adoption across teams. Verification & validation framework for safety-critical embedded systems.',
    tags: ['V&V', 'Embedded', 'Safety-Critical', 'EMSOFT 2025'],
    link: null,
    linkLabel: null,
  },
];
---

<Layout title="Jeroen Veen — AI/ML Engineer & Researcher">
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <p class="hero-label">dev.jeroenveen.nl</p>
        <h1 class="hero-title">Jeroen Veen</h1>
        <p class="hero-role">AI/ML Engineer & Researcher</p>
        <p class="hero-subtitle">
          I build production AI systems — from synthetic media pipelines and ML-scored news intelligence
          to AI-augmented engineering workflows. PhD (TU/e), Philips Research, HAN University.
        </p>
      </div>
    </section>

    <!-- Projects -->
    <section class="section" id="projects">
      <span class="section-label">Projects</span>
      <h2 class="section-title">What I've Built</h2>

      <div class="project-grid">
        {projects.map((p) => (
          <div class="project-card">
            <h3 class="project-title">{p.title}</h3>
            <p class="project-desc">{p.desc}</p>
            <div class="project-tags">
              {p.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            {p.link && (
              <a href={p.link} class="project-link" target="_blank" rel="noopener">
                {p.linkLabel}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Bio -->
    <section class="section" id="about">
      <span class="section-label">Background</span>
      <h2 class="section-title">About</h2>
      <div class="bio">
        <p>
          Engineering researcher at HAN University of Applied Sciences, working across AI/ML,
          biomedical engineering, embedded systems, and energy systems. My research spans rapid
          antibiotic susceptibility testing, point-of-care diagnostics, computer vision for
          Parkinson biomarkers, and AI-augmented engineering education.
        </p>
        <p>
          Previously at Philips Research. PhD from Eindhoven University of Technology (TU/e).
          Patent holder. I care about building systems that work in production, not just in notebooks.
        </p>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <nav class="footer-links">
      <a href="https://github.com/ducroq" target="_blank" rel="noopener">GitHub</a>
      <span class="sep">/</span>
      <a href="https://linkedin.com/in/jeroenveen" target="_blank" rel="noopener">LinkedIn</a>
      <span class="sep">/</span>
      <a href="https://jeroenveen.nl" target="_blank" rel="noopener">jeroenveen.nl</a>
    </nav>
  </footer>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, var(--amber-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 640px;
    text-align: center;
    position: relative;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    margin-bottom: 0.5rem;
  }

  .hero-role {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--amber);
    margin-bottom: 2rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── Section ── */
  .section {
    padding: 5rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1rem;
    display: block;
  }

  .section-title {
    margin-bottom: 2.5rem;
  }

  /* ── Project Grid ── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.25rem;
  }

  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .project-card:hover {
    border-color: var(--amber-dim);
    box-shadow: 0 0 24px var(--amber-glow);
  }

  .project-title {
    margin-bottom: 0.5rem;
  }

  .project-desc {
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    flex: 1;
  }

  .project-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: var(--surface-hover);
    border: 1px solid var(--border-subtle);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* ── Bio ── */
  .bio {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .bio p {
    font-size: 1rem;
    line-height: 1.7;
  }

  /* ── Footer ── */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 3rem 1.5rem;
    text-align: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .sep {
    color: var(--text-dim);
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: 50vh;
      padding: 4rem 1.5rem 2rem;
    }
  }
</style>
