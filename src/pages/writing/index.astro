---
import Layout from '../../layouts/Layout.astro';
import { articles, formatDate } from '../../data/writing.ts';

const sorted = [...articles].sort((a, b) => b.date.localeCompare(a.date));
---

<Layout
  title="Writing — dev.jeroenveen.nl"
  description="Occasional writing on production AI, EU-sovereign architecture, embedded engineering, and what I've learned shipping systems."
>
  <a href="#writing" class="skip-nav">Skip to writing</a>
  <main>
    <section class="hero">
      <div class="hero-inner">
        <nav class="writing-nav" aria-label="Site navigation">
          <a href="/">← dev.jeroenveen.nl</a>
        </nav>
        <p class="hero-label">Writing</p>
        <h1 class="hero-title">Occasional notes from production work</h1>
        <p class="hero-subtitle">
          Short write-ups on things I've built and what I learned building them —
          EU-sovereign AI, embedded DSP, MLOps, and the in-between.
        </p>
      </div>
    </section>

    <section class="section" id="writing">
      <ul class="article-list">
        {sorted.map((a) => (
          <li class="article-item">
            <a href={`/writing/${a.slug}/`} class="article-link">
              <div class="article-meta">
                <time datetime={a.date}>{formatDate(a.date)}</time>
                <span class="sep">·</span>
                <span>{a.readTime}</span>
              </div>
              <h2 class="article-title">{a.title}</h2>
              <p class="article-excerpt">{a.excerpt}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <footer class="site-footer">
    <nav class="footer-links">
      <a href="https://github.com/ducroq" target="_blank" rel="noopener">GitHub</a>
      <span class="sep">/</span>
      <a href="https://linkedin.com/in/jeroenveen" target="_blank" rel="noopener">LinkedIn</a>
      <span class="sep">/</span>
      <a href="https://jeroenveen.nl" target="_blank" rel="noopener">jeroenveen.nl</a>
      <span class="sep">/</span>
      <a href="https://jeroenveen.nl/contact/" target="_blank" rel="noopener">Contact</a>
    </nav>
  </footer>
</Layout>

<style>
  .hero {
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, var(--amber-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 640px;
    text-align: center;
    position: relative;
  }

  .writing-nav {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-bottom: 2rem;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    font-family: var(--font-mono);
    color: var(--amber);
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto;
    color: var(--text-muted);
  }

  .section {
    padding: 2rem 1.5rem 5rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .article-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: 2px solid var(--amber);
    border-radius: 12px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .article-item:hover {
    border-color: color-mix(in srgb, var(--amber) 50%, transparent);
    border-top-color: var(--amber);
    box-shadow: 0 0 24px color-mix(in srgb, var(--amber) 15%, transparent);
    transform: translateY(-2px);
  }

  .article-link {
    display: block;
    padding: 1.75rem;
    color: inherit;
    border: none;
  }

  .article-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .article-meta .sep {
    color: var(--border);
  }

  .article-title {
    font-size: clamp(1.2rem, 2.2vw, 1.4rem);
    margin-bottom: 0.6rem;
    color: var(--text);
  }

  .article-link:hover .article-title {
    color: var(--amber);
  }

  .article-excerpt {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: none;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 3rem 1.5rem;
    text-align: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .footer-links .sep {
    color: var(--text-dim);
  }
</style>
