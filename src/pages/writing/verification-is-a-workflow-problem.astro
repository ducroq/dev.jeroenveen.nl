      <span class="sep">/</span>
      <a href="https://www.linkedin.com/in/jeroen-veen-3244444/" target="_blank" rel="noopener">LinkedIn</a>
      <span class="sep">/</span>
      <a href="https://jeroenveen.nl" target="_blank" rel="noopener">jeroenveen.nl</a>
      <span class="sep">/</span>
      <a href="https://jeroenveen.nl/contact/" target="_blank" rel="noopener">Contact</a>
    </nav>
  </footer>
</Layout>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .article-nav {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-bottom: 3rem;
  }

  .article-header {
    margin-bottom: 3rem;
  }

  .article-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 1.25rem;
    display: block;
  }

  .article-title {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    line-height: 1.25;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .article-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    max-width: 60ch;
  }

  .article-meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .article-meta .sep {
    color: var(--border);
  }

  .article-body {
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .article-body p {
    color: var(--text);
    max-width: none;
    margin-bottom: 1.25rem;
  }

  .article-body code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    color: var(--amber);
  }

  .article-body a {
    border-bottom: 1px dotted var(--amber-dim);
  }
  .article-body a:hover {
    border-bottom-color: var(--text);
  }

  .article-body hr {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 3rem 0 2rem;
  }

  .article-figure {
    margin: 2.5rem 0;
  }

  .article-figure img {
    display: block;
    width: 100%;
    height: auto;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 3rem 1.5rem;
    text-align: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .footer-links .sep {
    color: var(--text-dim);
  }
</style>
